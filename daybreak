#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$ROOT_DIR/.env"
COMPOSE_FILE="$ROOT_DIR/deploy/docker-compose.dependencies.yml"
PID_FILE="$ROOT_DIR/.daybreak/daybreak.pid"
LOG_FILE="$ROOT_DIR/.daybreak/app.log"
DOCKER_CMD=()

say() {
    printf '\n[Daybreak] %s\n' "$1"
}

warn() {
    printf '\n[Daybreak] WARNING: %s\n' "$1" >&2
}

fail() {
    printf '\n[Daybreak] ERROR: %s\n' "$1" >&2
    exit 1
}

random_secret() {
    if command -v openssl >/dev/null 2>&1; then
        openssl rand -hex 24
    elif command -v od >/dev/null 2>&1; then
        od -An -N24 -tx1 /dev/urandom | tr -d ' \n'
    else
        fail "openssl or od is required to generate deployment secrets"
    fi
}

ensure_linux_amd64() {
    [ "$(uname -s)" = "Linux" ] || fail "daybreak.bin deployment supports Linux only"
    case "$(uname -m)" in
        x86_64|amd64) ;;
        *) fail "the current Daybreak sandbox image supports x86_64/amd64 only" ;;
    esac
}

ensure_env() {
    if [ -f "$ENV_FILE" ]; then
        return
    fi
    umask 077
    cat > "$ENV_FILE" <<EOF
TZ=Asia/Shanghai
DAYBREAK_BINARY=./daybreak.bin
DAYBREAK_DATA_DIR=.
DAYBREAK_LISTEN_ADDR=0.0.0.0
DAYBREAK_APP_PORT=8000
DAYBREAK_POSTGRES_IMAGE=postgres:16-alpine
DAYBREAK_SANDBOX_IMAGE=ghcr.io/linyisheng1/daybreak-sandbox:latest
DAYBREAK_DOCKER_SOCKET=/var/run/docker.sock
DAYBREAK_DB_HOST=127.0.0.1
DAYBREAK_DB_PORT=5432
DAYBREAK_DB_NAME=daybreak
DAYBREAK_DB_USER=root
DAYBREAK_DB_VOLUME=daybreak-pgdata
DAYBREAK_DB_PASSWORD=$(random_secret)
DAYBREAK_ADMIN_USERNAME=admin
DAYBREAK_ADMIN_EMAIL=admin@daybreak.local
DAYBREAK_ADMIN_PASSWORD=$(random_secret)
DAYBREAK_ENCRYPT_KEY=$(random_secret)
DAYBREAK_MODEL_BASE_URL=
DAYBREAK_MODEL_API_KEY=
DAYBREAK_MODEL_NAME=
EOF
    say "Created .env with random database, administrator, and encryption secrets."
}

load_env() {
    [ -f "$ENV_FILE" ] || fail ".env does not exist; run ./daybreak up first"
    set -a
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set +a

    : "${DAYBREAK_DB_PASSWORD:?DAYBREAK_DB_PASSWORD is required}"
    : "${DAYBREAK_ADMIN_PASSWORD:?DAYBREAK_ADMIN_PASSWORD is required}"
    : "${DAYBREAK_ENCRYPT_KEY:?DAYBREAK_ENCRYPT_KEY is required}"
    : "${DAYBREAK_DB_USER:=root}"
    : "${DAYBREAK_DB_NAME:=daybreak}"
    : "${DAYBREAK_DB_VOLUME:=daybreak-pgdata}"
    : "${DAYBREAK_DB_PORT:=5432}"
    : "${DAYBREAK_APP_PORT:=8000}"
    : "${DAYBREAK_DOCKER_SOCKET:=/var/run/docker.sock}"
    export DAYBREAK_DB_USER DAYBREAK_DB_NAME DAYBREAK_DB_VOLUME DAYBREAK_DB_PORT DAYBREAK_APP_PORT DAYBREAK_DOCKER_SOCKET
}

require_docker() {
    command -v docker >/dev/null 2>&1 || fail "Docker is not installed. Run: ./daybreak install-docker"

    if docker info >/dev/null 2>&1; then
        DOCKER_CMD=(docker)
    elif command -v sudo >/dev/null 2>&1 && sudo docker info >/dev/null 2>&1; then
        DOCKER_CMD=(sudo docker)
    else
        fail "Docker is unavailable. Start Docker, then run: ./daybreak fix-permissions"
    fi

    "${DOCKER_CMD[@]}" compose version >/dev/null 2>&1 \
        || fail "Docker Compose v2 is required"
}

docker_cmd() {
    "${DOCKER_CMD[@]}" "$@"
}

compose() {
    docker_cmd compose \
        --project-name daybreak \
        --env-file "$ENV_FILE" \
        -f "$COMPOSE_FILE" \
        "$@"
}

require_binary() {
    local binary="${DAYBREAK_BINARY:-./daybreak.bin}"
    case "$binary" in
        /*) ;;
        *) binary="$ROOT_DIR/${binary#./}" ;;
    esac
    [ -f "$binary" ] || fail "Daybreak binary not found: $binary"
    [ -x "$binary" ] || chmod u+x "$binary" || fail "cannot make Daybreak binary executable"
    DAYBREAK_BINARY_PATH="$binary"
}

require_socket_access() {
    [ -S "$DAYBREAK_DOCKER_SOCKET" ] \
        || fail "Docker socket not found: $DAYBREAK_DOCKER_SOCKET"
    if [ ! -r "$DAYBREAK_DOCKER_SOCKET" ] || [ ! -w "$DAYBREAK_DOCKER_SOCKET" ]; then
        fail "the current user cannot access $DAYBREAK_DOCKER_SOCKET. Run ./daybreak fix-permissions, then sign out and back in"
    fi
}

pull_dependencies() {
    say "Pulling PostgreSQL and sandbox dependencies."
    if ! compose --profile sandbox-image pull postgres sandbox-image; then
        fail "dependency image pull failed. For a private GHCR package, run ./daybreak registry-login and retry"
    fi
}

wait_for_database() {
    local state=""
    say "Waiting for PostgreSQL."
    for _ in $(seq 1 60); do
        state="$(docker_cmd inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' daybreak-postgres 2>/dev/null || true)"
        if [ "$state" = "healthy" ]; then
            return
        fi
        if [ "$state" = "unhealthy" ] || [ "$state" = "exited" ]; then
            compose logs --tail=100 postgres
            fail "PostgreSQL startup failed"
        fi
        sleep 2
    done
    compose logs --tail=100 postgres
    fail "PostgreSQL health check timed out"
}

sync_database_password() {
    local escaped_user escaped_password
    escaped_user="${DAYBREAK_DB_USER//\"/\"\"}"
    escaped_password="${DAYBREAK_DB_PASSWORD//\'/\'\'}"
    printf 'ALTER ROLE "%s" WITH PASSWORD '\''%s'\'';\n' "$escaped_user" "$escaped_password" \
        | docker_cmd exec -i daybreak-postgres \
            psql --set ON_ERROR_STOP=1 -U "$DAYBREAK_DB_USER" -d "$DAYBREAK_DB_NAME" >/dev/null \
        || fail "could not synchronize the PostgreSQL password with .env"
}

is_app_running() {
    [ -f "$PID_FILE" ] || return 1
    local pid
    pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

http_ready() {
    local url="http://127.0.0.1:${DAYBREAK_APP_PORT}/openapi.json"
    if command -v curl >/dev/null 2>&1; then
        curl -fsS "$url" >/dev/null 2>&1
    elif command -v wget >/dev/null 2>&1; then
        wget -q --spider "$url" >/dev/null 2>&1
    else
        (exec 3<>"/dev/tcp/127.0.0.1/${DAYBREAK_APP_PORT}") >/dev/null 2>&1
    fi
}

start_app() {
    if is_app_running; then
        say "Daybreak is already running with PID $(cat "$PID_FILE")."
        return
    fi
    rm -f "$PID_FILE"
    mkdir -p "$ROOT_DIR/.daybreak" "$ROOT_DIR/reports"
    require_binary
    require_socket_access
    if http_ready; then
        fail "port ${DAYBREAK_APP_PORT} already serves another application; stop the old Daybreak container or change DAYBREAK_APP_PORT"
    fi

    say "Starting daybreak.bin."
    (
        cd "$ROOT_DIR"
        nohup "$DAYBREAK_BINARY_PATH" >> "$LOG_FILE" 2>&1 &
        printf '%s\n' "$!" > "$PID_FILE"
    )

    local pid
    pid="$(cat "$PID_FILE")"
    for _ in $(seq 1 90); do
        if ! kill -0 "$pid" 2>/dev/null; then
            tail -n 100 "$LOG_FILE" 2>/dev/null || true
            rm -f "$PID_FILE"
            fail "daybreak.bin exited during startup"
        fi
        if http_ready; then
            return
        fi
        sleep 2
    done
    tail -n 100 "$LOG_FILE" 2>/dev/null || true
    fail "Daybreak HTTP health check timed out"
}

stop_app() {
    if ! is_app_running; then
        rm -f "$PID_FILE"
        return
    fi
    local pid
    pid="$(cat "$PID_FILE")"
    say "Stopping daybreak.bin."
    kill "$pid"
    for _ in $(seq 1 30); do
        if ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$PID_FILE"
            return
        fi
        sleep 1
    done
    kill -9 "$pid" 2>/dev/null || true
    rm -f "$PID_FILE"
}

cmd_up() {
    ensure_linux_amd64
    ensure_env
    load_env
    require_docker
    require_binary
    require_socket_access
    pull_dependencies
    compose up -d postgres
    wait_for_database
    sync_database_password
    start_app

    say "Daybreak is ready."
    printf '  URL:      http://127.0.0.1:%s\n' "$DAYBREAK_APP_PORT"
    printf '  Account:  %s\n' "${DAYBREAK_ADMIN_EMAIL:-admin@daybreak.local}"
    printf '  Password: stored in %s as DAYBREAK_ADMIN_PASSWORD\n' "$ENV_FILE"
    printf '  Sandbox:  %s\n' "${DAYBREAK_SANDBOX_IMAGE:-ghcr.io/linyisheng1/daybreak-sandbox:latest}"
}

cmd_down() {
    ensure_env
    load_env
    stop_app
    require_docker
    compose down
    say "Daybreak stopped. PostgreSQL data was preserved."
}

cmd_restart() {
    ensure_env
    load_env
    stop_app
    cmd_up
}

cmd_status() {
    ensure_env
    load_env
    require_docker
    if is_app_running; then
        printf 'Daybreak application: running (PID %s)\n' "$(cat "$PID_FILE")"
    else
        printf 'Daybreak application: stopped\n'
    fi
    compose ps
    if docker_cmd image inspect "${DAYBREAK_SANDBOX_IMAGE:-ghcr.io/linyisheng1/daybreak-sandbox:latest}" >/dev/null 2>&1; then
        printf 'Sandbox image: ready\n'
    else
        printf 'Sandbox image: missing\n'
    fi
}

cmd_logs() {
    ensure_env
    load_env
    require_docker
    touch "$LOG_FILE"
    tail -n 150 -F "$LOG_FILE" &
    local tail_pid=$!
    trap 'kill "$tail_pid" 2>/dev/null || true' EXIT INT TERM
    compose logs -f --tail=100 postgres
}

cmd_registry_login() {
    require_docker
    local username token
    read -r -p "GitHub username: " username
    read -r -s -p "GitHub token (read:packages): " token
    printf '\n'
    [ -n "$username" ] && [ -n "$token" ] || fail "username and token are required"
    printf '%s' "$token" | docker_cmd login ghcr.io -u "$username" --password-stdin
    unset token
}

cmd_fix_permissions() {
    command -v docker >/dev/null 2>&1 || fail "Docker is not installed. Run ./daybreak install-docker first"
    local target_user="${SUDO_USER:-$USER}"
    if [ "$(id -u)" -eq 0 ]; then
        groupadd -f docker
        if [ "$target_user" != "root" ]; then
            usermod -aG docker "$target_user"
        fi
    else
        command -v sudo >/dev/null 2>&1 || fail "sudo is required to update Docker group membership"
        sudo groupadd -f docker
        sudo usermod -aG docker "$target_user"
    fi
    say "Docker permissions updated for $target_user. Non-root users must sign out and back in before running ./daybreak up."
}

cmd_install_docker() {
    ensure_linux_amd64
    command -v curl >/dev/null 2>&1 || fail "curl is required to install Docker"
    command -v sudo >/dev/null 2>&1 || [ "$(id -u)" -eq 0 ] \
        || fail "root or sudo access is required to install Docker"

    local installer
    installer="$(mktemp)"
    trap 'rm -f "$installer"' EXIT
    curl -fsSL https://get.docker.com -o "$installer"
    say "Downloaded Docker's official convenience installer to $installer."
    if [ "$(id -u)" -eq 0 ]; then
        sh "$installer"
        systemctl enable --now docker 2>/dev/null || service docker start
    else
        sudo sh "$installer"
        sudo systemctl enable --now docker 2>/dev/null || sudo service docker start
    fi
    cmd_fix_permissions
}

cmd_doctor() {
    local failed=0
    printf 'Daybreak deployment diagnostics\n'
    printf '  OS:          %s %s\n' "$(uname -s)" "$(uname -m)"
    [ "$(uname -s)" = "Linux" ] || failed=1
    case "$(uname -m)" in x86_64|amd64) ;; *) failed=1 ;; esac

    if [ -f "$ENV_FILE" ]; then
        printf '  .env:        ready\n'
        load_env
    else
        printf '  .env:        missing (created by ./daybreak up)\n'
    fi
    if command -v docker >/dev/null 2>&1; then
        printf '  Docker CLI:  ready\n'
        if docker info >/dev/null 2>&1; then
            printf '  Docker API:  accessible\n'
        else
            printf '  Docker API:  inaccessible (run ./daybreak fix-permissions)\n'
            failed=1
        fi
        if docker compose version >/dev/null 2>&1; then
            printf '  Compose v2:  ready\n'
        else
            printf '  Compose v2:  missing\n'
            failed=1
        fi
    else
        printf '  Docker:      missing (run ./daybreak install-docker)\n'
        failed=1
    fi
    if [ -n "${DAYBREAK_DOCKER_SOCKET:-}" ] && [ -r "$DAYBREAK_DOCKER_SOCKET" ] && [ -w "$DAYBREAK_DOCKER_SOCKET" ]; then
        printf '  Docker sock: accessible\n'
    elif [ -n "${DAYBREAK_DOCKER_SOCKET:-}" ]; then
        printf '  Docker sock: inaccessible (%s)\n' "$DAYBREAK_DOCKER_SOCKET"
        failed=1
    fi
    if [ -f "$ROOT_DIR/${DAYBREAK_BINARY:-daybreak.bin}" ] || [ -f "${DAYBREAK_BINARY:-}" ]; then
        printf '  Binary:      ready\n'
    else
        printf '  Binary:      missing\n'
        failed=1
    fi
    return "$failed"
}

usage() {
    cat <<'EOF'
Usage: ./daybreak <command>

  up                 Pull dependencies and start Daybreak
  down               Stop Daybreak and PostgreSQL, preserving data
  restart            Restart dependencies and application
  status             Show application, database, and sandbox status
  logs               Follow application and PostgreSQL logs
  doctor             Diagnose the host without changing it
  install-docker     Install Docker Engine using Docker's official script
  fix-permissions    Add the current user to the docker group
  registry-login     Authenticate to GHCR using a token from stdin
EOF
}

cd "$ROOT_DIR"
case "${1:-up}" in
    up) cmd_up ;;
    down) cmd_down ;;
    restart) cmd_restart ;;
    status) cmd_status ;;
    logs) cmd_logs ;;
    doctor) cmd_doctor ;;
    install-docker) cmd_install_docker ;;
    fix-permissions) cmd_fix_permissions ;;
    registry-login) cmd_registry_login ;;
    help|-h|--help) usage ;;
    *) usage; exit 2 ;;
esac
