/**
 * Daybreak 部署配置
 * ===============
 *
 * 部署流程:
 * 1. sudo apt install -y docker.io && sudo systemctl enable --now docker
 * 2. sudo tee /etc/docker/daemon.json <<<EOF
 *    {"hosts": ["unix:///var/run/docker.sock", "tcp://127.0.0.1:2375"]}
 *    EOF
 *    sudo systemctl restart docker
 * 3. docker run -d --name daybreak-db \
 *      -e POSTGRES_DB=daybreak \
 *      -e POSTGRES_USER=postgres \
 *      -e POSTGRES_PASSWORD=daybreak123 \
 *      -p 5432:5432 postgres:16
 * 4. 复制此文件到 .daybreak/config.json，修改 encrypt_key 和 api_key
 * 5. pip install -r requirements.txt
 * 6. nohup python3 main.py &
 *
 * 初始账户: admin / admin@daybreak.local / admin123
 */
{
  "system": {
    "listen_addr": "0.0.0.0",
    "listen_port": 8000,
    "encrypt_key": "replace-with-at-least-32-random-characters",
    "bootstrap_admin": {
      "enabled": true,
      "username": "admin",
      "email": "admin@daybreak.local",
      "password": "admin"
    }
  },
  "database": {
    "host": "127.0.0.1",
    "port": 5432,
    "database": "daybreak",
    "username": "root",
    "password": "123456",
    "pool_size": 32,
    "max_overflow": 32,
    "pool_timeout_seconds": 30,
    "pool_recycle_seconds": 1800,
    "pool_pre_ping": true
  },
  "agent_runtime": {
    "main_max_turns": 1000,
    "subordinate_max_turns": 1000,
    "model_stream_idle_timeout_seconds": 300,
    "context_compression_enabled": true,
    "context_compression_trigger_ratio": 0.95,
    "context_compression_hard_stop_ratio": 0.98,
    "context_compression_target_ratio": 0.2,
    "context_compression_preserve_recent_ratio": 0.25,
    "context_compression_preserve_recent_items": 20,
    "context_compression_min_items": 12,
    "context_compression_summary_max_tokens": 8000
  },
  "agent_pool": {
    "max_size": 256,
    "ttl_seconds": 1800,
    "sweep_interval_seconds": 60
  },
  "agents": {
    "cso": {
      "code": "cso",
      "name": "破晓 Daybreak",
      "description": "Chief Security Officer",
      "base_url": "https://api.openai.com/v1",
      "api_key": "your-api-key-here",
      "model": "gpt-5.5",
      "use_responses": false,
      "context_window": 1000000
    },
    "cae": {
      "code": "cae",
      "name": "V3ra",
      "description": "Chief Audit Engineer",
      "base_url": "https://api.openai.com/v1",
      "api_key": "your-api-key-here",
      "model": "gpt-5.5",
      "use_responses": false,
      "context_window": 1000000
    },
    "cce": {
      "code": "cce",
      "name": "Nu1L",
      "description": "Chief Cryptography Engineer",
      "base_url": "https://api.openai.com/v1",
      "api_key": "your-api-key-here",
      "model": "gpt-5.5",
      "use_responses": false,
      "context_window": 1000000
    },
    "cie": {
      "code": "cie",
      "name": "L1ly",
      "description": "Chief Intelligence Engineer",
      "base_url": "https://api.openai.com/v1",
      "api_key": "your-api-key-here",
      "model": "gpt-5.5",
      "use_responses": false,
      "context_window": 1000000
    },
    "cpe": {
      "code": "cpe",
      "name": "Fr4nk",
      "description": "Chief Penetration Engineer",
      "base_url": "https://api.openai.com/v1",
      "api_key": "your-api-key-here",
      "model": "gpt-5.5",
      "use_responses": false,
      "context_window": 1000000
    },
    "cre": {
      "code": "cre",
      "name": "J4m3",
      "description": "Chief Reverse Engineer",
      "base_url": "https://api.openai.com/v1",
      "api_key": "your-api-key-here",
      "model": "gpt-5.5",
      "use_responses": false,
      "context_window": 1000000
    }
  }
}
