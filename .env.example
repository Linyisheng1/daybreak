# ./daybreak up creates .env automatically. Edit the model fields when ready.
TZ=Asia/Shanghai
DAYBREAK_APP_IMAGE=ghcr.io/linyisheng1/daybreak:latest
DAYBREAK_SANDBOX_IMAGE=ghcr.io/linyisheng1/daybreak-sandbox:latest
DAYBREAK_BOOTSTRAP_SANDBOX=true
DAYBREAK_DB_PORT=5432

DAYBREAK_ADMIN_USERNAME=admin
DAYBREAK_ADMIN_EMAIL=admin@daybreak.local
DAYBREAK_ADMIN_PASSWORD=replace-with-a-strong-password
DAYBREAK_DB_PASSWORD=replace-with-a-strong-database-password
DAYBREAK_ENCRYPT_KEY=replace-with-at-least-32-random-characters

DAYBREAK_MODEL_BASE_URL=
DAYBREAK_MODEL_API_KEY=
DAYBREAK_MODEL_NAME=
