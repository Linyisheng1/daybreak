# ./daybreak up creates .env automatically. Keep this file shell-compatible.
TZ=Asia/Shanghai
DAYBREAK_BINARY=./daybreak.bin
DAYBREAK_DATA_DIR=.
DAYBREAK_LISTEN_ADDR=0.0.0.0
DAYBREAK_APP_PORT=8000

# Default image sources use China-friendly mirrors. To use official sources, set:
# DAYBREAK_POSTGRES_IMAGE=postgres:16-alpine
# DAYBREAK_SANDBOX_IMAGE=ghcr.io/linyisheng1/daybreak-sandbox:latest
DAYBREAK_POSTGRES_IMAGE=docker.m.daocloud.io/postgres:16-alpine
DAYBREAK_SANDBOX_IMAGE=ghcr.nju.edu.cn/linyisheng1/daybreak-sandbox:latest
DAYBREAK_DOCKER_SOCKET=/var/run/docker.sock
DAYBREAK_DB_HOST=127.0.0.1
DAYBREAK_DB_PORT=5432
DAYBREAK_DB_NAME=daybreak
DAYBREAK_DB_USER=root
DAYBREAK_DB_VOLUME=daybreak-pgdata

DAYBREAK_ADMIN_USERNAME=admin
DAYBREAK_ADMIN_EMAIL=admin@daybreak.local
DAYBREAK_ADMIN_PASSWORD=admin
DAYBREAK_DB_PASSWORD=replace-with-a-strong-database-password
DAYBREAK_ENCRYPT_KEY=replace-with-at-least-32-random-characters

DAYBREAK_MODEL_BASE_URL=
DAYBREAK_MODEL_API_KEY=
DAYBREAK_MODEL_NAME=
